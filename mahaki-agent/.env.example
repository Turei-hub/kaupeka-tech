# Copy to .env and fill in. Never commit .env.

# Reasoning layer — which LLM answers: gemini | anthropic | openai
LLM_PROVIDER=gemini
# Optional model override; blank = provider default
# (gemini-2.5-flash / claude-opus-4-8 / gpt-4o-mini)
# LLM_MODEL=

# Gemini (free tier — get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Anthropic (paid — used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=

# openWakeWord (wake word) — no account or API key required
# Path to a custom trained .onnx model for "Mahaki".
# Leave unset to use the bundled "hey_jarvis" model while testing.
# OWW_MODEL_PATH=./models/mahaki.onnx
# Detection sensitivity 0-1 (lower = more sensitive). Default 0.4.
# OWW_THRESHOLD=0.4

# Whisper model size: tiny | base | small | medium | large-v3
# WHISPER_MODEL=base

# TTS
# TTS_ENGINE=pyttsx3
# TTS_VOICE_ID=
