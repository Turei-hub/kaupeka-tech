# Copy to .env and fill in. Never commit .env.

# Anthropic (reasoning layer)
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8

# openWakeWord (wake word) — no account or API key required
# Path to a custom trained .onnx model for "Mahaki".
# Leave unset to use the bundled "hey_jarvis" model while testing.
# OWW_MODEL_PATH=./models/mahaki.onnx

# Whisper model size: tiny | base | small | medium | large-v3
# WHISPER_MODEL=base

# TTS
# TTS_ENGINE=pyttsx3
# TTS_VOICE_ID=
