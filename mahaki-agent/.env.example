# Copy to .env and fill in. Never commit .env.

# Anthropic (reasoning layer)
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8

# Picovoice / Porcupine (wake word) — free key from https://console.picovoice.ai
PICOVOICE_ACCESS_KEY=
# Custom "Mahaki" keyword file trained on the Picovoice Console.
# Leave unset to use the built-in "porcupine" wake word while testing.
# PORCUPINE_KEYWORD_PATH=./models/mahaki_en_linux_v3_0_0.ppn

# Whisper model size: tiny | base | small | medium | large-v3
# WHISPER_MODEL=base

# TTS
# TTS_ENGINE=pyttsx3
# TTS_VOICE_ID=
